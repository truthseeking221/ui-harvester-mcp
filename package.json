{
  "name": "ui-harvester-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server extract design tokens/theme snapshot from any URL via Playwright render",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ui-harvester-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "start:dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "keywords": [],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.51.0",
    "pngjs": "^7.0.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
